# ============================================
# BSForge - Environment Variables
# ============================================
# cp .env.example .env && 실제 값 입력
# ============================================

# ============================================
# Application
# ============================================
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# ============================================
# Database (PostgreSQL)
# ============================================
DATABASE_URL=postgresql+asyncpg://bsforge:bsforge_password@db:5432/bsforge
DATABASE_URL_SYNC=postgresql://bsforge:bsforge_password@db:5432/bsforge

# ============================================
# LLM Gateway
# ============================================
LLM_API_BASE=https://api.anthropic.com/v1
LLM_API_KEY=
LLM_MODEL=anthropic/claude-sonnet-4-20250514

# ============================================
# TTS
# ============================================
# Edge TTS: free, no key needed
EDGE_TTS_ENABLED=true
# ElevenLabs: paid, high quality (main TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_ENABLED=false

# ============================================
# Content Sources
# ============================================
# Reddit API (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=BSForge/1.0

# ============================================
# Visual Assets
# ============================================
# Pexels (https://www.pexels.com/api/)
PEXELS_API_KEY=

# ============================================
# YouTube API
# ============================================
# Google Cloud Console OAuth 2.0 credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
YOUTUBE_CREDENTIALS_PATH=config/youtube_credentials.json
YOUTUBE_TOKEN_PATH=config/youtube_token.pickle

# ============================================
# File Storage
# ============================================
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./outputs

# ============================================
# Feature Flags
# ============================================
ENABLE_AUTO_UPLOAD=false

# ============================================
# Orchestrator
# ============================================
SCHEDULER_INTERVAL_HOURS=6
